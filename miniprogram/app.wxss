page {
  font-family: -apple-system, BlinkMacSystemFont, PingFang SC, Helvetica Neue, sans-serif;
  background-color: #F5F7FA;
  color: #1A1D29;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}
.page-container {
  padding: 32rpx;
  min-height: 100vh;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,29,41,0.06);
}
.btn-primary {
  background: linear-gradient(135deg, #5B7FFF, #7C5CFC);
  color: #fff;
  border-radius: 14rpx;
  padding: 24rpx 44rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  width: 100%;
  margin: 12rpx 0;
  letter-spacing: 2rpx;
}
.btn-primary:active { opacity: 0.85; }
.btn-danger {
  background: linear-gradient(135deg, #FF6B6B, #EE5A24);
  color: #fff;
  border-radius: 14rpx;
  padding: 24rpx 44rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
  width: 100%;
  margin: 12rpx 0;
}
.btn-danger:active { opacity: 0.85; }
.input-field {
  background: #F5F7FA;
  border-radius: 14rpx;
  padding: 24rpx 28rpx;
  height: 76rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  margin: 10rpx 0;
  color: #1A1D29;
}
.input-field:focus {
  border-color: #5B7FFF;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(91,127,255,0.10);
}
.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-blue { background: rgba(91,127,255,0.10); color: #5B7FFF; }
.tag-green { background: rgba(0,214,143,0.10); color: #00B87A; }
.empty-state { text-align: center; padding: 120rpx 0; color: #B0B4C0; font-size: 28rpx; }
.section-title { font-size: 34rpx; font-weight: 700; margin-bottom: 24rpx; color: #1A1D29; }
.progress-bar {
  height: 12rpx;
  background: #F0F2F5;
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-bar-inner {
  height: 100%;
  background: linear-gradient(90deg, #5B7FFF, #7C5CFC);
  border-radius: 6rpx;
  transition: width 0.3s;
}
.progress-bar-inner.completed { background: linear-gradient(90deg, #00D68F, #00C9A7); }