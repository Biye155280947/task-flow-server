.field-label { font-size: 28rpx; color: #5A6072; margin-top: 28rpx; margin-bottom: 8rpx; }
.textarea { height: 180rpx; line-height: 1.5; }
.check-group { margin: 12rpx 0; background: #F5F7FA; border-radius: 14rpx; overflow: hidden; }
.check-row { display: flex; align-items: center; padding: 20rpx 24rpx; border-bottom: 2rpx solid #F0F2F5; }
.check-row:last-child { border-bottom: none; }
.check-row:active { background: rgba(91,127,255,0.05); }
.check-native { margin-right: 14rpx; transform: scale(0.9); }
.check-name { font-size: 28rpx; color: #1A1D29; }
.empty-members { background: #FAFBFC; border-radius: 14rpx; padding: 32rpx 20rpx; text-align: center; margin: 12rpx 0; }
.empty-members-text { font-size: 26rpx; color: #8E92A0; display: block; }
.empty-members-hint { font-size: 22rpx; color: #C0C4D0; display: block; margin-top: 8rpx; }
.hint-text { color: #FF5C5C; font-size: 24rpx; margin-top: 6rpx; }
.picker-value { background: #F5F7FA; border-radius: 14rpx; padding: 22rpx 28rpx; font-size: 28rpx; color: #1A1D29; margin: 10rpx 0; }
