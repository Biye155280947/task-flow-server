.login-card { display: flex; flex-direction: column; align-items: center; padding: 160rpx 60rpx 60rpx; }
.login-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.login-title { font-size: 44rpx; color: #1A1D29; margin-bottom: 12rpx; }
.login-desc { font-size: 28rpx; color: #9EA4B4; margin-bottom: 60rpx; }
.login-hint { font-size: 24rpx; color: #C0C4D0; margin-top: 32rpx; }
.user-card { padding: 32rpx; }
.user-info { display: flex; align-items: center; background: #fff; border-radius: 20rpx; padding: 36rpx; margin-bottom: 24rpx; }
.user-avatar { width: 100rpx; height: 100rpx; border-radius: 50%; margin-right: 28rpx; background: #F0F2F5; }
.user-detail { flex: 1; }
.user-name { font-size: 36rpx; color: #1A1D29; display: block; }
.user-role { font-size: 24rpx; color: #5B7FFF; display: inline-block; background: rgba(91,127,255,0.10); padding: 4rpx 16rpx; border-radius: 20rpx; }
.user-id { font-size: 20rpx; color: #C0C4D0; display: block; word-break: break-all; }
.action-list { background: #fff; border-radius: 20rpx; margin-bottom: 24rpx; }
.action-item { display: flex; justify-content: space-between; align-items: center; padding: 30rpx 36rpx; border-bottom: 2rpx solid #F5F7FA; font-size: 30rpx; color: #1A1D29; }
.action-item:last-child { border-bottom: none; }
.action-item:active { background: #FAFBFC; }
.arrow { font-size: 36rpx; color: #D0D4E0; }
.badge-new { font-size: 20rpx; color: #fff; background: #FF5C5C; padding: 4rpx 14rpx; border-radius: 20rpx; margin-left: 12rpx; }
